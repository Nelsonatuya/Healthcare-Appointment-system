 "client_script": "frappe.web_form.on('after_save', (data) => {\r\n    const success_wrapper = $(\".success-state\");\r\n    const patient_id = (data && (data.patient || data.name)) || (frappe.web_form.doc && frappe.web_form.doc.name);\r\n\r\n    if (!patient_id) return;\r\n\r\n    try {\r\n        localStorage.setItem('book_appointment_patient', patient_id);\r\n    } catch (e) {\r\n        // Ignore storage errors and continue with URL-based flow.\r\n    }\r\n\r\n    const target_url = '/book-an-appointment/new?patient=' + encodeURIComponent(patient_id);\r\n    const existing_link = document.querySelector('.book-appointment-btn') || document.querySelector('.success-state a.btn-primary');\r\n    if (existing_link) existing_link.href = target_url;\r\n\r\n    if (success_wrapper.length) {\r\n        success_wrapper.find('.new-btn').remove();\r\n        if (!document.querySelector('.success-state .book-now-btn')) {\r\n            success_wrapper.append(`\r\n                <div style=\"margin-top: 20px;\">\r\n                    <p>Your registration is complete! You can now schedule your first visit.</p>\r\n                    <button class=\"btn btn-primary btn-lg book-now-btn\" \r\n                            onclick=\"window.location.href='${target_url}'\" \r\n                            style=\"width: 100%; font-weight: bold;\">\r\n                        Book Your Appointment Now\r\n                    </button>\r\n                </div>\r\n            `);\r\n        }\r\n    }\r\n});",
